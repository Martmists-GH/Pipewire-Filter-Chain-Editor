pkgname=pfce-bin
pkgver=1.0.1
pkgrel=1
pkgdesc="A graphical node editor for PipeWire filter chains"
arch=('x86_64')

provides=('pfce')
depends=('freetype2' 'pipewire' 'ladspa')

url='https://github.com/Martmists-GH/Pipewire-Filter-Chain-Editor'
source=(
    "https://github.com/Martmists-GH/Pipewire-Filter-Chain-Editor/releases/download/${pkgver}/pfce-${pkgver}.tar.gz"
    'pfce.desktop'
)
sha256sums=(
    'SKIP'
    '1727bfbe50633b452e2212d5aefe37301afc24125903e4e67c7bc25addd35132'
)

package() {
    # Install to /opt/pfce
    install -d "${pkgdir}/opt/pfce"
    cp -a "${srcdir}/bin" "${srcdir}/lib" "${pkgdir}/opt/pfce"

    # Create wrapper script
    install -d "${pkgdir}/usr/bin"
    cat <<EOF > "${srcdir}/pfce-wrapper"
#!/bin/bash
export LD_PRELOAD=/usr/lib/libfreetype.so
exec "/opt/pfce/bin/Pipewire Filter Chain Editor" "\$@"
EOF

    # Install wrapper as main binary
    install -Dm755 "${srcdir}/pfce-wrapper" "${pkgdir}/usr/bin/pfce"

    # Add desktop file to applications
    install -Dm644 "${srcdir}/pfce.desktop" "${pkgdir}/usr/share/applications/pfce.desktop"
}
